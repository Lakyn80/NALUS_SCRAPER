# LLM provider (deepseek / openai)
LLM_PROVIDER=deepseek
LLM_API_KEY=your-api-key-here
LLM_MODEL_DEEPSEEK=deepseek-chat
LLM_TIMEOUT=30
LLM_MAX_TOKENS=800

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=nalus

# Optional exact query cache
RAG_QUERY_CACHE_BACKEND=none
RAG_QUERY_CACHE_URL=redis://redis:6379/0
RAG_QUERY_CACHE_TTL_SECONDS=604800
RAG_QUERY_CACHE_PROMPT_VERSION=v1

# RAG
RAG_STRICT_REAL_MODE=1
NALUS_BATCHES_DIR=/app/batches
NALUS_CHUNK_SIZE=1500
NALUS_CHUNK_OVERLAP=200

# Embedding
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=1
